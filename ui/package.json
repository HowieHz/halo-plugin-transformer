{
  "type": "module",
  "scripts": {
    "build": "run-s verify:spec-artifacts build:compiled",
    "build-only": "rsbuild build",
    "build:compiled": "run-p type-check \"build-only {@}\" --",
    "dev": "rsbuild build --watch --env-mode=development",
    "fmt": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less,scss}\" --ignore-path ../.gitignore",
    "fmt:check": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less,scss}\" --check --ignore-path ../.gitignore",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path ../.gitignore",
    "test:unit": "vitest --passWithNoTests",
    "type-check": "vue-tsc --build",
    "verify:spec-artifacts": "pnpm --dir .. verify:spec-artifacts"
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.24.0",
    "@halo-dev/components": "^2.24.0",
    "@halo-dev/ui-shared": "^2.24.0",
    "axios": "^1.15.1",
    "canvas-confetti": "^1.9.4",
    "compat-finder": "^1.3.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "^2.24.0",
    "@iconify-json/ri": "^1.2.10",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-sass": "^1.5.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@unocss/eslint-config": "^66.6.8",
    "@unocss/postcss": "^66.6.8",
    "@unocss/webpack": "^66.6.8",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-oxlint": "^1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "sass": "^1.99.0",
    "typescript": "~6.0.3",
    "unocss": "^66.6.8",
    "unplugin-icons": "^23.0.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": ">=24",
    "pnpm": "^10.33.0"
  },
  "packageManager": "pnpm@10.33.0"
}
