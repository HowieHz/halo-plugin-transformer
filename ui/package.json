{
  "type": "module",
  "scripts": {
    "build": "run-s verify:spec-artifacts build:compiled",
    "build-only": "rsbuild build",
    "build:compiled": "run-p type-check \"build-only {@}\" --",
    "dev": "rsbuild build --watch --env-mode=development",
    "fmt": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less,scss}\" --ignore-path ../.gitignore",
    "fmt:check": "oxfmt \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less,scss}\" --check --ignore-path ../.gitignore",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path ../.gitignore",
    "test:unit": "vitest --passWithNoTests",
    "type-check": "vue-tsc --build",
    "verify:spec-artifacts": "pnpm --dir .. verify:spec-artifacts"
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.25.2",
    "@halo-dev/components": "^2.25.2",
    "@halo-dev/ui-shared": "^2.25.2",
    "axios": "^1.18.1",
    "canvas-confetti": "^1.9.4",
    "compat-finder": "^2.1.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "^2.25.2",
    "@iconify-json/ri": "^1.2.10",
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-sass": "^2.0.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@unocss/eslint-config": "^66.7.5",
    "@unocss/postcss": "^66.7.5",
    "@unocss/webpack": "^66.7.5",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-vue": "~10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "sass": "^1.101.0",
    "typescript": "~6.0.3",
    "unocss": "^66.7.5",
    "unplugin-icons": "^23.0.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=24",
    "pnpm": "^11.13.0"
  },
  "packageManager": "pnpm@11.13.0"
}
